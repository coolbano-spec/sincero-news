rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own subscriptions document
    match /subscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Backwards compatibility for users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Debug simulated emails can be read/written in the dev sandbox
    match /simulated_emails/{docId} {
      allow read, write: if true;
    }
  }
}
